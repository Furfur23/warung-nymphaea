# ============================================================
#  MIDTRANS PAYMENT GATEWAY — Konfigurasi .env
#  Salin baris-baris ini ke file .env Laravel kamu
#
#  Dapatkan credential Sandbox di:
#  https://dashboard.sandbox.midtrans.com
#  Settings → Access Keys
# ============================================================

MIDTRANS_MERCHANT_ID=G123456789
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# ============================================================
#  Untuk Production (live), ubah:
#    MIDTRANS_IS_PRODUCTION=true
#    MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxxxxxxxxxxxxx  (tanpa prefix SB-)
#    MIDTRANS_SERVER_KEY=Mid-server-xxxxxxxxxxxxxxxxxxxx  (tanpa prefix SB-)
#
#  JANGAN pernah commit Server Key ke Git!
#  Pastikan .env ada di .gitignore
# ============================================================

# ============================================================
#  WEBHOOK / NOTIFICATION URL (wajib dikonfigurasi di dashboard Midtrans)
#  Settings → Configuration → Payment Notification URL:
#
#    [Sandbox]    https://your-domain.test/webhook/midtrans
#    [Production] https://your-domain.com/webhook/midtrans
#
#  Untuk lokal, gunakan ngrok atau Expose:
#    ngrok http 8000
#    → pakai URL ngrok sebagai Notification URL di dashboard
# ============================================================
